{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    {
      "source": "/attain-test",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*([Ww]hats[Aa]pp|[Ff]acebook|[Tt]witterbot|[Tt]elegram[Bb]ot|[Dd]iscordbot|[Ss]lackbot|[Ll]inked[Ii]n[Bb]ot|[Ee]mbedly|[Gg]ooglebot|[Bb]ingbot|[Gg]oogle-[Ss]tructured).*?"
        }
      ],
      "destination": "/api/og-preview?type=attain"
    },
    {
      "source": "/start-mock-test/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*([Ww]hats[Aa]pp|[Ff]acebook|[Tt]witterbot|[Tt]elegram[Bb]ot|[Dd]iscordbot|[Ss]lackbot|[Ll]inked[Ii]n[Bb]ot|[Ee]mbedly|[Gg]ooglebot|[Bb]ingbot|[Gg]oogle-[Ss]tructured).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=start"
    },
    {
      "source": "/show-mock-test/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*([Ww]hats[Aa]pp|[Ff]acebook|[Tt]witterbot|[Tt]elegram[Bb]ot|[Dd]iscordbot|[Ss]lackbot|[Ll]inked[Ii]n[Bb]ot|[Ee]mbedly|[Gg]ooglebot|[Bb]ingbot|[Gg]oogle-[Ss]tructured).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=show"
    },
    {
      "source": "/mock-test-result/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*([Ww]hats[Aa]pp|[Ff]acebook|[Tt]witterbot|[Tt]elegram[Bb]ot|[Dd]iscordbot|[Ss]lackbot|[Ll]inked[Ii]n[Bb]ot|[Ee]mbedly|[Gg]ooglebot|[Bb]ingbot|[Gg]oogle-[Ss]tructured).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=result"
    },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=UTF-8" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    }
  ]
}
