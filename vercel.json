{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    {
      "source": "/attain-test",
      "has": [
        {
          "type": "query",
          "key": "paperid",
          "value": "(?<paperid>[a-zA-Z0-9_-]+)"
        },
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|twitterbot|whatsapp|telegrambot|discordbot|slackbot|linkedinbot|embedly|googlebot|bingbot|Google-Structured-Data-Testing-Tool).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperid&type=attain"
    },
    {
      "source": "/start-mock-test/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|twitterbot|whatsapp|telegrambot|discordbot|slackbot|linkedinbot|embedly|googlebot|bingbot|Google-Structured-Data-Testing-Tool).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=start"
    },
    {
      "source": "/show-mock-test/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|twitterbot|whatsapp|telegrambot|discordbot|slackbot|linkedinbot|embedly|googlebot|bingbot|Google-Structured-Data-Testing-Tool).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=show"
    },
    {
      "source": "/mock-test-result/:paperId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|twitterbot|whatsapp|telegrambot|discordbot|slackbot|linkedinbot|embedly|googlebot|bingbot|Google-Structured-Data-Testing-Tool).*?"
        }
      ],
      "destination": "/api/og-preview?paperId=:paperId&type=result"
    },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=UTF-8" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    }
  ]
}
